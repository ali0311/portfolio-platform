# =============================================================================
# Production env template for the backend running on EC2.
# Copy to `.env` on the server and fill in real values.
# Never commit the real `.env`.
# =============================================================================

# Server
NODE_ENV=production
PORT=4000

# Postgres (lives on the same EC2, internal Docker network)
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=replace-with-strong-random-string
POSTGRES_DB=portfolio
DATABASE_URL=postgresql://portfolio:replace-with-strong-random-string@postgres:5432/portfolio?schema=public

# JWT
JWT_SECRET=replace-with-`openssl rand -hex 32`-output
JWT_EXPIRES_IN=12h

# Admin user (auto-seeded on first boot, idempotent on rebuild)
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=replace-with-strong-password

# CORS — must match the CloudFront URL exactly (no trailing slash)
# After Phase 5 you'll know the real CloudFront domain — replace this.
FRONTEND_ORIGIN=https://YOUR-CLOUDFRONT-ID.cloudfront.net
