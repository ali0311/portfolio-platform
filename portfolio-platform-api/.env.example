# Server
NODE_ENV=development
PORT=4000

# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5433/portfolio?schema=public"

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# Admin seed (used by `npm run seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-locally

# Frontend origin (for CORS + cookies)
FRONTEND_ORIGIN=http://localhost:5173
