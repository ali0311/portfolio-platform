# ============================================================================
# Portfolio Platform — Local Docker Compose configuration
# Copy to `.env` and fill in real values before running `docker compose up`.
# ============================================================================

# Postgres
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio

# Backend
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# Admin user (auto-seeded on first boot, idempotent on rebuilds)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-locally

# CORS origin the API will accept (web container's exposed URL)
FRONTEND_ORIGIN=http://localhost:8080

# Public URL the frontend bundle should call.
# Bake this into the Vite build at image-build time.
VITE_API_URL=http://localhost:4000
